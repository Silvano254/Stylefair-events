# ============================================
# ENVIRONMENT VARIABLES - TEMPLATE
# Copy this file to .env.local for development
# Copy this file to .env.production for production
# NEVER commit actual credentials to version control
# ============================================

# ============================================
# EMAIL CONFIGURATION (REQUIRED)
# ============================================
# Gmail account email address
NODEMAILER_USER=stylefairevents@gmail.com

# Gmail App-Specific Password (NOT your Gmail password)
# Generate at: myaccount.google.com/apppasswords
# Select "Mail" and "Windows Computer"
# Copy the 16-character password
NODEMAILER_PASS=xxxx xxxx xxxx xxxx

# ============================================
# CORS & ORIGIN CONFIGURATION
# ============================================
# Allowed origins for API requests (production domain)
# Multiple domains separated by commas
# Leave blank or use * for development (NOT recommended for production)
ALLOWED_ORIGINS=https://stylefair-events.vercel.app,https://www.stylefairevents.com

# ============================================
# DEPLOYMENT ENVIRONMENT
# ============================================
# Set to 'production' for Vercel deployment
# Set to 'development' for local testing
NODE_ENV=production

# ============================================
# RATE LIMITING CONFIGURATION (OPTIONAL)
# ============================================
# Maximum inquiries per IP address per hour
RATE_LIMIT_MAX_REQUESTS=50

# Rate limit window in milliseconds (1 hour = 3600000ms)
RATE_LIMIT_WINDOW=3600000

# ============================================
# EMAIL SERVICE CONFIGURATION (OPTIONAL)
# ============================================
# Request timeout in milliseconds
EMAIL_TIMEOUT=10000

# Total operation timeout (includes retries)
EMAIL_MAX_TIMEOUT=15000

# Maximum request payload size in bytes (50KB)
MAX_PAYLOAD_SIZE=52428800

# ============================================
# LOGGING CONFIGURATION (OPTIONAL)
# ============================================
# Set to 'true' to enable detailed logging
DEBUG=false

# Log email addresses (security consideration)
LOG_EMAIL_ADDRESSES=false

# ============================================
# IMPORTANT SECURITY NOTES
# ============================================
# 1. GMAIL APP PASSWORD
#    - NOT your regular Gmail password
#    - Generate at myaccount.google.com/apppasswords
#    - Requires 2FA enabled on your Gmail account
#    - Format: 4 groups of 4 characters (e.g., xxxx xxxx xxxx xxxx)
#
# 2. CORS ORIGINS
#    - Specify exact domains for production
#    - DO NOT use wildcard (*) in production
#    - Include www and non-www versions if needed
#
# 3. RATE LIMITING
#    - Prevents spam and abuse
#    - Current default: 50 requests per hour per IP
#    - Adjust based on expected traffic
#
# 4. ENVIRONMENT SEPARATION
#    - Never commit .env files with real credentials
#    - Use .env.local for development
#    - Use .env.production for Vercel secrets
#    - Use Vercel dashboard for production secrets
#
# 5. DEPLOYMENT
#    - All secrets must be set in Vercel dashboard
#    - Settings > Environment Variables
#    - Select "Production" scope for NODEMAILER_PASS

# ============================================
# VERIFICATION CHECKLIST
# ============================================
# Before deploying to production, verify:
# [ ] Gmail 2FA is enabled
# [ ] App Password generated and copied correctly
# [ ] All variables set in Vercel dashboard
# [ ] ALLOWED_ORIGINS matches your domain
# [ ] NODE_ENV set to 'production'
# [ ] No credentials in version control
# [ ] .env files added to .gitignore
# [ ] Local .env.local file exists but not committed
# [ ] Vercel preview environment has separate secrets
# [ ] Production environment has all required secrets
# [ ] Form submission tested on live site
# [ ] Email notifications received successfully
