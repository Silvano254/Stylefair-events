# ============================================
# GIT IGNORE - SECURITY SENSITIVE FILES
# Prevent accidental commits of credentials
# ============================================

# ============================================
# ENVIRONMENT VARIABLES
# ============================================
# Never commit environment files with real credentials
.env.local
.env.production
.env.development
.env.*.local
.env

# ============================================
# DEPENDENCIES
# ============================================
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# IDE & EDITOR
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.env.code-workspace
*.sublime-workspace

# ============================================
# BUILD & DISTRIBUTION
# ============================================
dist/
build/
.next/
out/
.vercel/

# ============================================
# LOGS & DEBUG
# ============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================
# OPERATING SYSTEM
# ============================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ============================================
# TESTING
# ============================================
coverage/
.nyc_output/

# ============================================
# TEMPORARY FILES
# ============================================
tmp/
temp/
*.tmp

# ============================================
# OS SPECIFIC
# ============================================
.vscode-test/
.eslintcache
